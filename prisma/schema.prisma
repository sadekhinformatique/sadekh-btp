generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  properties Property[]
  favorites  Favorite[]
  sentMessages   Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  payments   Payment[]
  reports    Report[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String?
  phone       String?
  whatsapp    String?
  agencyName  String?
  role        String   @default("user")
  verified    Boolean  @default(false)
  bio         String?
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id              String    @id @default(cuid())
  userId          String
  type            String    @default("maison") // maison, appartement, terrain, plan
  title           String
  description     String
  price           Float
  priceNegotiable Boolean   @default(false)
  surfaceM2       Int?
  rooms           Int?
  region          String    @default("Dakar")
  city            String?
  quartier        String?
  lat             Float?
  lng             Float?
  images          String    @default("[]") // JSON array of URLs
  titleFoncier    Boolean   @default(false)
  status          String    @default("active") // draft, active, sold, suspended
  isPremium       Boolean   @default(false)
  viewsCount      Int       @default(0)
  planPdfUrl      String?
  planPrice       Float?
  planDownloads   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites       Favorite[]
  messages        Message[]
  reports         Report[]
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@unique([userId, propertyId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  propertyId String?
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  sender     User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  type       String   // boost, plan, premium
  amount     Float
  method     String   @default("wave") // wave, orange_money
  status     String   @default("pending") // pending, completed, failed
  refWave    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  propertyId String
  reason     String
  createdAt  DateTime @default(now())
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}